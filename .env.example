# Global
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/common_ground

# Redis / Queue
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-me

# Auth
NEXTAUTH_SECRET=replace-with-at-least-32-random-characters
OAUTH_EXCHANGE_SECRET=replace-with-a-separate-32-character-secret
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me

# API
API_BASE_URL=http://localhost:4100
API_PROCESS_ROLE=all

# LLM Providers
ANTHROPIC_API_KEY=replace-me
OPENAI_API_KEY=replace-me

# Email and storage
RESEND_API_KEY=replace-me
RESEND_FROM_EMAIL="Common Ground <onboarding@resend.dev>"
TWILIO_ACCOUNT_SID=replace-me
TWILIO_AUTH_TOKEN=replace-me
TWILIO_FROM_PHONE=+15551234567
SMS_MFA_SECRET=replace-with-a-separate-32-character-secret
S3_BUCKET=common-ground-exports
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me

# Observability
SENTRY_DSN=replace-me

# Beta feature flags
ENABLE_SAML=false
ENABLE_PUBLIC_REGISTRATION=false
ENABLE_BILLING=false
ENABLE_SMS_MFA=false
ENABLE_EXTERNAL_EXPORT_STORAGE=false
ENABLE_DATADOG=false
NEXT_PUBLIC_ENABLE_SMS_MFA=false
NEXT_PUBLIC_ENABLE_REGISTRATION=false
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
NEXT_PUBLIC_MICROSOFT_AUTH_ENABLED=false
