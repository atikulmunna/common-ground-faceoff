generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  draft
  collecting_positions
  queued
  running
  completed
  failed
  needs_input
}

enum ParticipantRole {
  session_creator
  session_participant
  observer
}

enum UserTier {
  free
  pro
  enterprise
}

enum ModerationSeverity {
  low
  medium
  high
  critical
}

enum RedactionStage {
  detect
  mask
  validate
  uncertainty_check
}

model User {
  id               String               @id @default(cuid())
  email            String               @unique
  displayName      String
  passwordHash     String?
  emailVerified    Boolean              @default(false)
  avatarUrl        String?
  notificationPrefs Json?
  tier             UserTier             @default(free)
  role             String               @default("individual_user")
  mfaEnabled       Boolean              @default(false)
  mfaSecret        String?
  smsMfaEnabled    Boolean              @default(false)
  smsPhone         String?
  smsCodeHash      String?
  smsCodeExpiresAt DateTime?
  smsCodePurpose   String?
  organizationId   String?
  samlNameId       String?
  stripeCustomerId String?              @unique
  failedLoginCount Int                  @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime             @default(now())
  lastLoginAt      DateTime?
  sessions         Session[]            @relation("SessionCreator")
  participants     SessionParticipant[]
  feedback         FeedbackRating[]
  refreshTokens    RefreshToken[]
  organization     Organization?        @relation(fields: [organizationId], references: [id])
  cohortMemberships CohortMembership[]
  subscription     Subscription?
  emailInvitations EmailInvitation[]
  emailVerificationTokens EmailVerificationToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id                String               @id @default(cuid())
  topic             String
  status            SessionStatus         @default(draft)
  creatorUserId     String
  creator           User                 @relation("SessionCreator", fields: [creatorUserId], references: [id])
  anonymousMode     Boolean              @default(false)
  deadline          DateTime?
  lastActivityAt    DateTime?
  maxParticipants   Int                  @default(6)
  estimatedCompletionAt DateTime?
  createdAt         DateTime             @default(now())
  analyzedAt        DateTime?
  participants      SessionParticipant[]
  analysisResults   AnalysisResult[]
  analysisEvents    AnalysisEvent[]
  shareLinks        ShareLink[]
  emailInvitations  EmailInvitation[]
  positionSnapshots PositionSnapshot[]
  promptLogs        PromptLog[]
}

model SessionParticipant {
  id                   String            @id @default(cuid())
  sessionId             String
  userId                String
  role                  ParticipantRole  @default(session_participant)
  canExport             Boolean           @default(false)
  positionText          String?
  positionSubmittedAt   DateTime?
  session               Session           @relation(fields: [sessionId], references: [id])
  user                  User              @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
}

// CG-FR68: Per-round position snapshots for re-entry lineage
model PositionSnapshot {
  id            String   @id @default(cuid())
  sessionId     String
  userId        String
  roundNumber   Int
  positionText  String
  snapshotAt    DateTime @default(now())
  session       Session  @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, userId, roundNumber])
  @@index([sessionId, roundNumber])
}

model AnalysisResult {
  id                        String   @id @default(cuid())
  sessionId                  String
  roundNumber                Int      @default(1)
  parentSessionOrRoundId     String?
  pipelineRunId              String
  analysisVersion            String
  promptTemplateVersion      String
  promptTemplateHash         String?
  inputHash                  String
  steelmans                  Json
  conflictMap                Json
  sharedFoundations          String
  trueDisagreements          String
  confidenceScores           Json
  llmProvider                String
  modelVersion               String
  status                     SessionStatus
  createdAt                  DateTime @default(now())
  session                    Session  @relation(fields: [sessionId], references: [id])

  @@index([sessionId, roundNumber])
}

model AnalysisEvent {
  id            String   @id @default(cuid())
  sessionId      String
  pipelineRunId  String
  eventType      String
  fromState      String?
  toState        String?
  reasonCode     String?
  actorType      String
  createdAt      DateTime @default(now())
  session        Session  @relation(fields: [sessionId], references: [id])
}

model ShareLink {
  id                String   @id @default(cuid())
  sessionId          String
  token              String   @unique
  scope              String   @default("read_only")
  createdByUserId    String
  revoked            Boolean  @default(false)
  revocationReason   String?
  expiresAt          DateTime?
  createdAt          DateTime @default(now())
  session            Session  @relation(fields: [sessionId], references: [id])
}

model FeedbackRating {
  id            String   @id @default(cuid())
  sessionId      String
  userId         String
  faithfulness   Int
  neutrality     Int
  comment        String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])

  @@index([sessionId])
}

model SectionReaction {
  id            String   @id @default(cuid())
  sessionId      String
  userId         String
  section        String   // e.g. "steelman:ParticipantA", "sharedFoundations", "trueDisagreements"
  reaction       String   // "represents", "misrepresents", "neutral"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([sessionId, userId, section])
  @@index([sessionId])
}

model AuditLog {
  id         String   @id @default(cuid())
  eventType  String
  actorId    String?
  actorEmail String?
  ip         String?
  detail     String?
  createdAt  DateTime @default(now())

  @@index([eventType])
  @@index([actorId])
}

model SectionComment {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  section   String
  text      String
  createdAt DateTime @default(now())

  @@index([sessionId])
}

model Organization {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  samlEntryPoint  String?
  samlCert        String?
  samlIssuer      String?
  forceAnonymous  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  users           User[]
  cohorts         Cohort[]
}

model Cohort {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  createdAt DateTime @default(now())
  org       Organization @relation(fields: [orgId], references: [id])
  members   CohortMembership[]

  @@index([orgId])
}

model CohortMembership {
  id        String   @id @default(cuid())
  cohortId  String
  userId    String
  addedAt   DateTime @default(now())
  cohort    Cohort   @relation(fields: [cohortId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([cohortId, userId])
}

model RedactionLog {
  id             String          @id @default(cuid())
  sessionId      String
  participantId  String
  stage          RedactionStage
  findingsCount  Int             @default(0)
  confidence     Float
  blocked        Boolean         @default(false)
  metadata       Json?
  createdAt      DateTime        @default(now())

  @@index([sessionId])
}

model ModerationFlag {
  id            String             @id @default(cuid())
  sessionId     String
  reportedBy    String
  reason        String
  section       String?
  severity      ModerationSeverity @default(medium)
  autoDetected  Boolean            @default(false)
  status        String             @default("pending")  // pending, approved, edited, deleted, appealed
  reviewedBy    String?
  reviewNotes   String?
  editedContent String?
  appealText    String?
  appealStatus  String?            // pending_appeal, upheld, overturned
  slaDueAt      DateTime?
  slaBreachedAt DateTime?
  createdAt     DateTime           @default(now())
  reviewedAt    DateTime?

  @@index([sessionId])
  @@index([status])
}

model Subscription {
  id                    String   @id @default(cuid())
  userId                String   @unique
  stripeCustomerId      String   @unique
  stripeSubscriptionId  String   @unique
  stripePriceId         String
  status                String   @default("active")
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model EmailInvitation {
  id          String    @id @default(cuid())
  sessionId   String
  email       String
  invitedById String
  status      String    @default("pending") // pending, sent, accepted, expired
  sentAt      DateTime?
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  session     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([sessionId, email])
  @@index([sessionId])
  @@index([email])
}

model NotificationEmail {
  id                String   @id @default(cuid())
  kind              String
  recipientEmail    String
  sessionId         String?
  payload           Json?
  status            String   @default("pending") // pending, retrying, sent, failed
  attempts          Int      @default(0)
  nextAttemptAt     DateTime @default(now())
  lastAttemptAt     DateTime?
  lastError         String?
  providerMessageId String?
  sentAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status, nextAttemptAt])
  @@index([sessionId])
}

model WebhookEvent {
  id         String   @id @default(cuid())
  provider   String
  eventId    String
  eventType  String
  processed  Boolean  @default(false)
  payload    Json?
  createdAt  DateTime @default(now())

  @@unique([provider, eventId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// CG-NFR32: Consent provenance records
model ConsentRecord {
  id            String   @id @default(cuid())
  userId        String
  purpose       String   // e.g. "analysis_processing", "email_notifications", "data_sharing"
  lawfulBasis   String   // e.g. "consent", "legitimate_interest", "contract"
  granted       Boolean  @default(true)
  ipAddress     String?
  userAgent     String?
  version       Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([purpose])
}

// CG-NFR31: Data subject request lifecycle
model DataSubjectRequest {
  id            String   @id @default(cuid())
  userId        String
  requestType   String   // "export", "deletion", "rectification", "restriction"
  status        String   @default("received") // received, verified, in_progress, fulfilled, rejected
  reason        String?
  fulfilledAt   DateTime?
  rejectedAt    DateTime?
  rejectionNote String?
  deadlineAt    DateTime // auto-set based on request type
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// CG-NFR33: Versioned subprocessor inventory
model SubprocessorEntry {
  id          String   @id @default(cuid())
  name        String
  purpose     String
  dataTypes   String   // comma-separated: "position_text,email,display_name"
  location    String   // e.g. "US", "EU"
  dpaUrl      String?  // link to Data Processing Agreement
  version     Int      @default(1)
  active      Boolean  @default(true)
  addedAt     DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
}

// CG-FR30: LLM prompt/response audit log (PII stripped before storage)
model PromptLog {
  id              String   @id @default(cuid())
  sessionId       String
  pipelineRunId   String
  stage           String   // normalization, steelman, value_extraction, conflict_classification, synthesis
  provider        String
  model           String
  systemPrompt    String   // PII-free system prompt
  userPrompt      String   // PII-stripped user prompt
  responseText    String   // PII-stripped response
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  durationMs      Int      @default(0)
  createdAt       DateTime @default(now())

  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([pipelineRunId])
}
