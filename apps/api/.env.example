# === REQUIRED ===
PORT=4100
API_PROCESS_ROLE=all
DATABASE_URL=postgresql://user:password@localhost:5432/common_ground
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/common_ground_test
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32
OAUTH_EXCHANGE_SECRET=replace-me-with-a-separate-32-character-secret
CORS_ORIGIN=http://localhost:3000

# === LLM PROVIDERS (at least one required for analysis) ===
MISTRAL_API_KEY=          # Primary — https://console.mistral.ai
GROQ_API_KEY=             # Fallback — https://console.groq.com
OPENROUTER_API_KEY=       # Optional 2nd fallback — https://openrouter.ai

# === OPTIONAL (needed for specific features) ===
API_BASE_URL=http://localhost:4100
NEXTAUTH_URL=http://localhost:3000
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-me
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
SENDGRID_API_KEY=replace-me
SENTRY_DSN=replace-me

# === BETA FEATURE FLAGS (secure defaults) ===
ENABLE_SAML=false
ENABLE_PUBLIC_REGISTRATION=false
ENABLE_BILLING=false
ENABLE_SMS_MFA=false
ENABLE_EXTERNAL_EXPORT_STORAGE=false
ENABLE_DATADOG=false
